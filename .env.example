# === Услуги Бензо — Backend ENV ===

# Пароли для входа в админ-панель (обязательны)
ADMIN_PASS_1=твой_секретный_пароль
ADMIN_PASS_2=пароль_бензо

# Откуда разрешены CORS-запросы
CORS_ORIGIN=https://benzoservices.github.io

# Порт сервера (по умолчанию 3001)
PORT=3001

# Путь к SQLite базе данных
DB_PATH=data/data.db
